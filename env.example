# Backend (Rails) - ejemplo de variables de entorno
#
# Copiá este archivo como `backend/.env` (NO se commitea) y completá los valores.

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# OAuth (Admin login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Portal inversores: contraseña inicial compartida para emails que no son @gmail.com / @googlemail.com
# (además de la contraseña propia hasheada por inversor). Dejar vacío para desactivar.
INVESTOR_SHARED_LOGIN_PASSWORD=

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

